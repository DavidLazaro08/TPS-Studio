<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    Layout raíz: StackPane con dos capas.
    Capa 1 (abajo): BorderPane con toolbar + paneles laterales + canvas.
    Capa 2 (encima): rightPanel como overlay alineado TOP_RIGHT con margen superior
               igual a la altura de la toolbar (~46px), para que nunca la solape.
    Ventaja: el canvas NO cambia de tamaño al abrir/cerrar el panel; en su lugar
             el canvas se desplaza suavemente con TranslateTransition (adjustCanvasCentering).
-->
<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.tpsstudio.view.controllers.MainViewController"
           styleClass="root">

    <!-- CAPA 1: Layout principal -->
    <BorderPane fx:id="rootPane">

        <!-- BARRA SUPERIOR -->
        <top>
            <VBox>
                <HBox alignment="CENTER_LEFT" styleClass="main-toolbar" spacing="0">
                    <padding>
                        <Insets top="6" bottom="6" left="10" right="10" />
                    </padding>

                    <!-- GRUPO 1: Selector de Modo (Segmentado) -->
                    <HBox spacing="0" alignment="CENTER_LEFT" styleClass="toolbar-group">
                        <fx:define>
                            <ToggleGroup fx:id="modeToggleGroup" />
                        </fx:define>
                        <ToggleButton fx:id="btnModeExport" text="Producción" toggleGroup="$modeToggleGroup"
                                      onAction="#onModeExport" styleClass="mode-toggle-left" selected="true" />
                        <ToggleButton fx:id="btnModeEdit" text="Diseño" toggleGroup="$modeToggleGroup"
                                      onAction="#onModeEdit" styleClass="mode-toggle-right" />
                    </HBox>

                    <Separator orientation="VERTICAL" styleClass="toolbar-separator" />

                    <!-- GRUPO 2: Acciones de Archivo -->
                    <HBox spacing="4" alignment="CENTER_LEFT" styleClass="toolbar-group">
                        <Button fx:id="btnNuevo" text="📄" onAction="#onNuevoProyecto" styleClass="icon-btn">
                            <tooltip><Tooltip text="Nuevo Proyecto" /></tooltip>
                        </Button>
                        <Button fx:id="btnAbrir" text="📂" onAction="#onAbrirProyecto" styleClass="icon-btn">
                            <tooltip><Tooltip text="Abrir Proyecto" /></tooltip>
                        </Button>
                        <Button fx:id="btnGuardar" text="💾" onAction="#onGuardarProyecto" styleClass="icon-btn">
                            <tooltip><Tooltip text="Guardar Cambios" /></tooltip>
                        </Button>
                    </HBox>

                    <Separator orientation="VERTICAL" styleClass="toolbar-separator" />

                    <!-- GRUPO 3: Salida / Producción -->
                    <HBox spacing="6" alignment="CENTER_LEFT" styleClass="toolbar-group">
                        <Button fx:id="btnExportar" text="📤 PDF" onAction="#onExportarProyecto" styleClass="action-btn">
                            <tooltip><Tooltip text="Generar archivo PDF para exportación" /></tooltip>
                        </Button>
                        <Button fx:id="btnImprimir" text="🖨 Imprimir" onAction="#onImprimirProyecto" styleClass="action-btn-primary">
                            <tooltip><Tooltip text="Lanzar diálogo de impresión de tarjetas" /></tooltip>
                        </Button>
                    </HBox>

                    <Separator orientation="VERTICAL" styleClass="toolbar-separator" />

                    <!-- GRUPO 4: Herramientas de Lienzo -->
                    <HBox spacing="6" alignment="CENTER_LEFT" styleClass="toolbar-group">
                        <!-- Zoom -->
                        <HBox alignment="CENTER_LEFT" spacing="2" styleClass="zoom-container">
                            <Button text="-" onAction="#onZoomOut" styleClass="zoom-btn" />
                            <Label fx:id="lblZoom" text="100%" styleClass="zoom-label" />
                            <Button text="+" onAction="#onZoomIn" styleClass="zoom-btn" />
                        </HBox>
                        
                        <Separator orientation="VERTICAL" styleClass="inner-separator" />
                        
                        <ToggleButton fx:id="toggleFrenteDorso" text="Frente" onAction="#onToggleFrenteDorso"
                                      styleClass="view-toggle" selected="true" />
                        <ToggleButton fx:id="toggleGuias" text="Guías" onAction="#onToggleGuias"
                                      styleClass="view-toggle" selected="true" />
                        
                        <HBox alignment="CENTER_LEFT" spacing="4" styleClass="troquel-container">
                            <Label text="Troquel:" styleClass="toolbar-hint" />
                            <ComboBox fx:id="cmbTroquelToolbar" promptText="Sin troquel" prefWidth="120"
                                      styleClass="toolbar-combo" />
                        </HBox>
                    </HBox>

                    <!-- Espaciador Flexible -->
                    <Region HBox.hgrow="ALWAYS" />

                    <!-- GRUPO 5: Paneles Laterales -->
                    <HBox fx:id="bloqueContextual" spacing="6" alignment="CENTER_LEFT" visible="false" managed="false" styleClass="toolbar-group">
                        <Separator orientation="VERTICAL" styleClass="toolbar-separator" />
                        <ToggleButton fx:id="togglePropiedades" text="⚙ Propiedades" onAction="#onTogglePropiedades"
                                      styleClass="panel-toggle" />
                        <ToggleButton fx:id="toggleDatosVariables" text="📊 Datos" onAction="#onToggleDatosVariables"
                                      styleClass="panel-toggle" />
                    </HBox>
                </HBox>
            </VBox>
        </top>

        <left>
            <VBox styleClass="side-panel" prefWidth="240" minWidth="200" maxWidth="300">
                <!-- Zona superior: Proyectos / Herramientas (ahora sin scroll global) -->
                <VBox fx:id="leftPanel" VBox.vgrow="ALWAYS" />
                
                <Separator />
                
                <!-- Zona inferior: Perfil de Usuario -->
                <VBox fx:id="userProfileArea" spacing="8" alignment="CENTER_LEFT" styleClass="user-profile-panel">
                    <padding>
                        <Insets top="12" bottom="12" left="15" right="15" />
                    </padding>
                    <Label fx:id="lblCurrentUser" text="Usuario: Admin" styleClass="user-profile-name" />
                    <Button fx:id="btnLogout" text="Cerrar Sesión" onAction="#onLogout" styleClass="logout-btn" />
                </VBox>
            </VBox>
        </left>

        <!-- ÁREA DE TRABAJO (Canvas) -->
        <center>
            <StackPane fx:id="canvasContainer" styleClass="canvas-area">
                <Canvas fx:id="canvas" width="750" height="600" />
            </StackPane>
        </center>

    </BorderPane>

    <!-- CAPA 2: Panel derecho como overlay — empieza bajo la toolbar (margen 46px) -->
    <VBox fx:id="rightPanel" styleClass="side-panel"
          prefWidth="290" minWidth="290" maxWidth="290"
          visible="false" managed="false">
        <StackPane.alignment>TOP_RIGHT</StackPane.alignment>
        <StackPane.margin>
            <Insets top="46" />
        </StackPane.margin>
    </VBox>

</StackPane>
