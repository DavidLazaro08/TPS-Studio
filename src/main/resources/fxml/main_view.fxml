<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    Layout raíz: StackPane con dos capas.
    Capa 1 (abajo): BorderPane con toolbar + paneles laterales + canvas.
    Capa 2 (encima): rightPanel como overlay alineado TOP_RIGHT con margen superior
               igual a la altura de la toolbar (~46px), para que nunca la solape.
    Ventaja: el canvas NO cambia de tamaño al abrir/cerrar el panel; en su lugar
             el canvas se desplaza suavemente con TranslateTransition (adjustCanvasCentering).
-->
<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.tpsstudio.view.controllers.MainViewController"
           styleClass="root">

    <!-- CAPA 1: Layout principal -->
    <BorderPane fx:id="rootPane">

        <!-- BARRA SUPERIOR -->
        <top>
            <VBox>
                <HBox alignment="CENTER_LEFT" styleClass="toolbar" spacing="10">
                    <padding>
                        <Insets top="8" bottom="8" left="12" right="12" />
                    </padding>

                    <!-- BLOQUE 1: Modo -->
                    <fx:define>
                        <ToggleGroup fx:id="modeToggleGroup" />
                    </fx:define>

                    <ToggleButton fx:id="btnModeExport" text="📦 Producción" toggleGroup="$modeToggleGroup"
                                  onAction="#onModeExport" styleClass="mode-toggle" selected="true" />
                    <ToggleButton fx:id="btnModeEdit" text="🎨 Diseño" toggleGroup="$modeToggleGroup"
                                  onAction="#onModeEdit" styleClass="mode-toggle" />

                    <Separator orientation="VERTICAL" />

                    <!-- BLOQUE 2: Archivo / Proyecto -->
                    <Button fx:id="btnNuevo" text="Nuevo" onAction="#onNuevoProyecto" styleClass="toolbar-btn" />
                    <Button fx:id="btnAbrir" text="Abrir" onAction="#onAbrirProyecto" styleClass="toolbar-btn" />
                    <Button fx:id="btnGuardar" text="Guardar" onAction="#onGuardarProyecto" styleClass="toolbar-btn" />
                    <Button fx:id="btnExportar" text="Exportar" onAction="#onExportarProyecto" styleClass="toolbar-btn" />
                    <Button fx:id="btnImprimir" text="🖨 Imprimir" onAction="#onImprimirProyecto" styleClass="toolbar-btn" />

                    <Separator orientation="VERTICAL" />

                    <!-- BLOQUE 3: Vista / Documento -->
                    <Button text="-" onAction="#onZoomOut" styleClass="toolbar-btn-small" />
                    <Label fx:id="lblZoom" text="100%" styleClass="toolbar-label" />
                    <Button text="+" onAction="#onZoomIn" styleClass="toolbar-btn-small" />

                    <Separator orientation="VERTICAL" />

                    <ToggleButton fx:id="toggleFrenteDorso" text="Frente" onAction="#onToggleFrenteDorso"
                                  styleClass="toolbar-toggle" selected="true" />

                    <ToggleButton fx:id="toggleGuias" text="Guías" onAction="#onToggleGuias"
                                  styleClass="toolbar-toggle" selected="true" />

                    <ComboBox fx:id="cmbTroquelToolbar" promptText="Sin Troquel" prefWidth="130"
                              styleClass="toolbar-combo" />

                    <Separator orientation="VERTICAL" />

                    <!-- BLOQUE 4: Paneles contextuales (solo visibles en modo Diseño) -->
                    <HBox fx:id="bloqueContextual" spacing="6" alignment="CENTER_LEFT" visible="false" managed="false">
                        <ToggleButton fx:id="togglePropiedades" text="⚙ Propiedades" onAction="#onTogglePropiedades"
                                      styleClass="toolbar-toggle" />
                        <ToggleButton fx:id="toggleDatosVariables" text="📊 Datos Variables" onAction="#onToggleDatosVariables"
                                      styleClass="toolbar-toggle" />
                    </HBox>
                </HBox>
            </VBox>
        </top>

        <left>
            <VBox styleClass="side-panel" prefWidth="240" minWidth="200" maxWidth="300">
                <!-- Zona superior: Proyectos / Herramientas (ahora sin scroll global) -->
                <VBox fx:id="leftPanel" VBox.vgrow="ALWAYS" />
                
                <Separator />
                
                <!-- Zona inferior: Perfil de Usuario -->
                <VBox fx:id="userProfileArea" spacing="8" alignment="CENTER_LEFT" styleClass="user-profile-panel">
                    <padding>
                        <Insets top="12" bottom="12" left="15" right="15" />
                    </padding>
                    <Label fx:id="lblCurrentUser" text="Usuario: Admin" styleClass="user-profile-name" />
                    <Button fx:id="btnLogout" text="Cerrar Sesión" onAction="#onLogout" styleClass="logout-btn" />
                </VBox>
            </VBox>
        </left>

        <!-- ÁREA DE TRABAJO (Canvas) -->
        <center>
            <StackPane fx:id="canvasContainer" styleClass="canvas-area">
                <Canvas fx:id="canvas" width="750" height="600" />
            </StackPane>
        </center>

    </BorderPane>

    <!-- CAPA 2: Panel derecho como overlay — empieza bajo la toolbar (margen 46px) -->
    <VBox fx:id="rightPanel" styleClass="side-panel"
          prefWidth="290" minWidth="290" maxWidth="290"
          visible="false" managed="false">
        <StackPane.alignment>TOP_RIGHT</StackPane.alignment>
        <StackPane.margin>
            <Insets top="46" />
        </StackPane.margin>
    </VBox>

</StackPane>
